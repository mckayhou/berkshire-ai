# Berkshire AI 环境变量模板
# 复制为 .env 后填入真实值；.env 已被 .gitignore 忽略，切勿提交真实密钥。
# 体检：python3 src/config.py   （显示各功能就绪度，不打印密钥明文）
#
# 全部变量均为可选——不配置时核心离线能力仍可用（实时检索/LLM 改写/远端推送等
# 对应功能降级或跳过）。

# --- 实时检索（src/tavily_search.py + skills/anysearch）---
# 多 Key 轮询，逗号分隔；或用单 Key 的 TAVILY_API_KEY
TAVILY_API_KEYS=
# AnySearch Skill / hybrid 回退（https://www.anysearch.com/docs）
# 也可写在 skills/anysearch/.env；切勿提交真实 Key
ANYSEARCH_API_KEY=
# auto | tavily | anysearch | hybrid
SEARCH_MODE=hybrid
# hybrid 下双侧合并去重：1/true
SEARCH_SUPPLEMENT=

# --- LLM：Option B prompt 改写（src/prompt_optimizer.py）---
# 兜底可用 OPENAI_API_KEY
BERKSHIRE_LLM_API_KEY=
# OpenAI 兼容网关地址（默认 https://api.openai.com/v1）
BERKSHIRE_LLM_BASE_URL=
# 模型名（默认 gpt-4o-mini）
BERKSHIRE_LLM_MODEL=

# --- 引擎（src/realized_feedback.py / src/decision_log.py）---
# 覆盖收益→真相分灵敏度（默认 0.5，V10.12 校准值）
BERKSHIRE_SENSITIVITY=
# 决策日志落盘路径（默认 ~/.berkshire/decisions.jsonl）
BERKSHIRE_DECISION_LOG=
# 经验库 JSONL（默认 ~/.berkshire/experiences.jsonl）
BERKSHIRE_EXPERIENCE_LOG=
# Run 记录 JSONL（默认 ~/.berkshire/runs.jsonl）
BERKSHIRE_RUN_LOG=
# NetworkPriceProvider 可选磁盘缓存目录（留空=仅内存缓存）
BERKSHIRE_PRICE_CACHE_DIR=
BERKSHIRE_PRICE_CACHE_TTL=
# 置 1 关闭 Yahoo chart 无依赖回退（默认：data_sources 空时自动回退美股/ADR）
BERKSHIRE_DISABLE_YAHOO_FALLBACK=
# 轨迹目录（默认 ~/.qwenpaw/berkshire_traces）
BERKSHIRE_TRACE_DIR=
# aktools-pro HTTP 后端（需本地服务；置 1 启用）
BERKSHIRE_ENABLE_AKTOOLS=
BERKSHIRE_AKTOOLS_BASE_URL=http://127.0.0.1:8080

# --- 服务边界（src/service.py，需 pip install .[service]）---
# 受保护端点 /score /debate 的 API Key（逗号分隔；留空=不鉴权，仅限内网/开发）
BERKSHIRE_API_KEYS=
# 每客户端每分钟限流（0/留空=关闭；生产建议 60~300）
BERKSHIRE_RATE_LIMIT_PER_MIN=
# 监听地址/端口（默认 0.0.0.0:8000）
BERKSHIRE_HOST=
BERKSHIRE_PORT=

# --- A 股数据降级链（tools/data_sources.py）---
# 覆盖默认优先级链 native→tushare→efinance→akshare→baostock→yfinance
BERKSHIRE_DATA_SOURCES=
# 置 1 启用 tushare 源（需同时给 TUSHARE_TOKEN）
BERKSHIRE_ENABLE_TUSHARE=
TUSHARE_TOKEN=

# --- 问财自然语言选股（.agents/skills/pywencai，来自 finance-quant-skills）---
# 浏览器登录 iwencai.com 后从 DevTools 复制 Cookie；留空则 Agent 跳过问财源
WENCAI_COOKIE=

# --- 量化数据融合（V10.24，见 docs/quant_data_fusion.md）---
# daily_stock_data 落盘目录（含 daily_ohlcv.csv）
BERKSHIRE_DATA_DIR=./data
# 置 1 启用本地 CSV 源 LocalCsvSource
BERKSHIRE_ENABLE_LOCAL_DATA=
# 置 1 启用 pytdx 实时源（需 pip install .[quant]）
BERKSHIRE_ENABLE_PYTDX=
BERKSHIRE_PYTDX_HOST=119.147.212.81
BERKSHIRE_PYTDX_PORT=7709
# 通达信 MCP（外部 tdx_quant 脚本用，本仓库不内置）
TDX_API_KEY=
# AlphaGPT 外部仓库路径（仅文档边界，默认不调用）
BERKSHIRE_ALPHAGPT_REPO=
BERKSHIRE_ENABLE_ALPHAGPT=
# A 股因子挖掘（tools/ashare_factor_mining.py，需 pip install '.[factor-mining]'）
BERKSHIRE_ALPHAGPT_CODE=511260
BERKSHIRE_ALPHAGPT_START=20150101
BERKSHIRE_ALPHAGPT_TRAIN_END=20240101
BERKSHIRE_ALPHAGPT_TEST_END=20250101
BERKSHIRE_ALPHAGPT_STEPS=400
BERKSHIRE_ALPHAGPT_BATCH=1024
BERKSHIRE_ALPHAGPT_MAX_LEN=8
BERKSHIRE_ALPHAGPT_COST=0.0005
BERKSHIRE_ALPHAGPT_SPLIT=0.8
BERKSHIRE_ALPHAGPT_DAILY_LIMIT=3000
BERKSHIRE_ALPHAGPT_MIN_BARS=80
BERKSHIRE_ALPHAGPT_SCORE_MIN=0.0
BERKSHIRE_LIMITUP_SCORE_MIN=60
BERKSHIRE_LIMITUP_MIN_BARS=22

# --- 多通道推送（tools/notify.py）---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
FEISHU_WEBHOOK=
FEISHU_SECRET=
